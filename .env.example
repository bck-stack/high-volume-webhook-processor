# Optional: HMAC-SHA256 secret for verifying incoming webhooks
WEBHOOK_SECRET=your_signing_secret_here

# Supabase connection (optional — falls back to in-memory store)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_TABLE=webhook_logs

# Max number of logs returned by GET /logs
MAX_LOGS_RESPONSE=50
